{
  "manifest_version": 3,
  "name": "Tab URL Saver",
  "description": "A browser action with a popup dump of all bookmarks, including search, add, edit and delete.",
  "version": "1.0",
  "permissions": [
    "bookmarks",
    "tabs",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["saved_urls.html", "saved_urls.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

